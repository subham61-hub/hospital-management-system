# This is an example .env file. Copy it to .env and fill in your actual credentials.
# DO NOT commit the .env file to version control.

# Django Settings
SECRET_KEY="your-super-secret-django-key-here"
DEBUG=True

# Email Microservice URL (if running on a different port/host)
EMAIL_MICROSERVICE_URL="http://localhost:3000/dev/send-email"

# Serverless Email Handler SMTP Credentials (e.g., for Gmail App Password)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your_email@gmail.com"
SMTP_PASSWORD="your_gmail_app_password"